<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
               https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <service id="druidvav.sentry_extension.exception_listener"
                 class="Druidvav\SentryExtensionBundle\EventListener\SentryExceptionListener">
            <argument type="service" id="Sentry\State\HubInterface"/>
        </service>

        <service id="druidvav.sentry_extension.kernel_exception_listener"
                 class="Druidvav\SentryExtensionBundle\EventListener\SentryKernelExceptionListener">
            <argument type="service" id="druidvav.sentry_extension.exception_listener"/>
            <tag name="kernel.event_listener"
                 event="kernel.exception"
                 method="onKernelException"
                 priority="2048"/>
        </service>

    </services>

</container>
